// Configuração do Cliente Prisma
generator client {
  provider = "prisma-client-js"
}

// Configuração da conexão com o MySQL no Docker
datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

// Modelo de Perfil de Autor
model authorprofile {
  id            Int     @id @default(autoincrement())
  biography     String? @db.Text
  userId        Int     @unique(map: "userId")
  socialProfile String? @db.VarChar(500)
  users         users   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "authorprofile_ibfk_1")
}

// Modelo de Categorias
model categories {
  id    Int     @id @default(autoincrement())
  name  String  @db.VarChar(100)
  posts posts[]
}

// Modelo de Comentários
model comments {
  id          Int       @id @default(autoincrement())
  text        String    @db.Text
  commentDate DateTime? @default(now()) @db.DateTime(0)
  postId      Int
  userId      Int
  posts       posts     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comments_ibfk_1")
  users       users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comments_ibfk_2")

  @@index([postId], map: "postId")
  @@index([userId], map: "userId")
}

// Modelo de Posts
model posts {
  id               Int        @id @default(autoincrement())
  title            String     @db.VarChar(755)
  content          String     @db.Text
  publication_date DateTime?  @default(now()) @db.DateTime(0)
  authorId         Int
  categorieId      Int
  comments         comments[]
  users            users      @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "posts_ibfk_1")
  categories       categories @relation(fields: [categorieId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "posts_ibfk_2")

  @@index([authorId], map: "authorId")
  @@index([categorieId], map: "categorieId")
}

// Modelo de Usuários
model users {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  email         String         @unique(map: "email") @db.VarChar(100)
  password      String         @db.VarChar(255)
  type          users_type?    @default(leitor)
  data_criacao  DateTime?      @default(now()) @db.DateTime(0)

  verificationCodeHash    String?   @db.VarChar(255)
  verificationExpiredAt   DateTime? @db.DateTime(0)
  isVerified              Boolean   @default(false) 
     
  authorprofile authorprofile?
  comments      comments[]
  posts         posts[]
}

// Definição dos tipos de usuário conforme o banco.sql
enum users_type {
  leitor
  autor
  admin
}